{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "mindoodb-app-sdk": ["../mindoodb-app-sdk/src/index.ts"],
      "mindoodb-app-sdk/testing": ["../mindoodb-app-sdk/src/testing/index.ts"],
      "mindoodb-view-language": ["../mindoodb-view-language/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
