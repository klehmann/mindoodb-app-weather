{
  "name": "mindoodb-app-weather",
  "version": "1.0.0",
  "description": "MindooDB Haven sample app: responsive iOS-style weather tile backed by the free Open-Meteo APIs",
  "license": "ISC",
  "author": "Mindoo GmbH",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "vite --port 4205",
    "dev:local": "LOCAL_MINDOODB=1 vite --port 4205",
    "build": "vue-tsc --noEmit && vite build",
    "build:local": "LOCAL_MINDOODB=1 vue-tsc --noEmit && LOCAL_MINDOODB=1 vite build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mindoodb-app-sdk": "0.0.16",
    "mindoodb-view-language": "0.0.11",
    "swiper": "^12.1.2",
    "vue": "^3.5.31",
    "vue-i18n": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.81.0"
  }
}
